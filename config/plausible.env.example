# /srv/plausible/config/plausible.env
# Copy this to plausible.env and fill in values
# Never commit plausible.env — only this example

BASE_URL=https://analytics.dapla.net
SECRET_KEY_BASE=GENERATE_WITH: openssl rand -base64 64
DATABASE_URL=postgresql://plausible:CHANGE_ME@plausible-db:5432/plausible
CLICKHOUSE_DATABASE_URL=http://plausible-events-db:8123/plausible_events_db

# SMTP — use your existing mail relay
MAILER_EMAIL=analytics@dapla.net
SMTP_HOST_ADDR=mail.dapla.net
SMTP_HOST_PORT=587
SMTP_USER_NAME=analytics@dapla.net
SMTP_USER_PWD=CHANGE_ME
SMTP_HOST_SSL_ENABLED=false
SMTP_RETRIES=2

# Disable registration after initial setup
DISABLE_REGISTRATION=true

# Optional: IP geolocation
# MAXMIND_LICENSE_KEY=
# MAXMIND_EDITION=GeoLite2-City
