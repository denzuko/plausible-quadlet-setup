# containers/plausible-events-db.container
# ClickHouse for Plausible CE event storage — rootless Podman quadlet
#
# Image pinned to:
#   tag:    docker.io/clickhouse/clickhouse-server:24.3.3.102-alpine
#   digest: sha256:8312f0ee358cbe122d78f9753ea0eb851355383d17c2a94df664f384757e141a (amd64)
# Update: check https://hub.docker.com/r/clickhouse/clickhouse-server/tags

[Unit]
Description=Plausible ClickHouse
After=network-online.target

[Container]
Image=docker.io/clickhouse/clickhouse-server:24.3.3.102-alpine@sha256:8312f0ee358cbe122d78f9753ea0eb851355383d17c2a94df664f384757e141a
ContainerName=plausible-events-db
Network=plausible.network

Volume=plausible-clickhouse.volume:/var/lib/clickhouse:Z
Volume=plausible-clickhouse-logs.volume:/var/log/clickhouse-server:Z

DropCapability=ALL
AddCapability=CHOWN FOWNER SETUID SETGID
NoNewPrivileges=false

Label=net.matrix.owner=FC13F74B@matrix.net
Label=net.matrix.project=plausible-quadlet-setup

[Service]
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
