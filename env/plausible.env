# env/plausible.env — Plausible CE environment template
# Installed to %h/.config/containers/systemd/plausible.env
# Fill in all CHANGE_ME values before starting

BASE_URL=https://analytics.dapla.net

# Generate: openssl rand -base64 64 | tr -d '\n'
SECRET_KEY_BASE=CHANGE_ME

DATABASE_URL=postgresql://plausible:CHANGE_ME@plausible-db:5432/plausible
CLICKHOUSE_DATABASE_URL=http://plausible-events-db:8123/plausible_events_db

MAILER_EMAIL=analytics@dapla.net
SMTP_HOST_ADDR=mail.dapla.net
SMTP_HOST_PORT=587
SMTP_USER_NAME=analytics@dapla.net
SMTP_USER_PWD=CHANGE_ME
SMTP_HOST_SSL_ENABLED=false
SMTP_RETRIES=2

DISABLE_REGISTRATION=true
